{
  "name": "rqmd",
  "displayName": "rqmd — AI Agent Bundle",
  "description": "Distributes the rqmd AI agent bundle (prompts, skills, agent definitions) via VS Code Copilot Chat contribution points. No files written to your project.",
  "version": "0.2.0",
  "publisher": "ryeleo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryeleo/rqmd"
  },
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "rqmd",
    "requirements",
    "copilot",
    "agent",
    "ai"
  ],
  "activationEvents": [
    "onCommand:rqmd.initProject"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rqmd.initProject",
        "title": "rqmd: Initialize Project",
        "category": "rqmd"
      }
    ],
    "chatPromptFiles": [
      { "path": "./prompts/brainstorm.prompt.md" },
      { "path": "./prompts/bug.prompt.md" },
      { "path": "./prompts/commit-and-go.prompt.md" },
      { "path": "./prompts/commit.prompt.md" },
      { "path": "./prompts/feedback.prompt.md" },
      { "path": "./prompts/go.prompt.md" },
      { "path": "./prompts/next.prompt.md" },
      { "path": "./prompts/pin.prompt.md" },
      { "path": "./prompts/polish-docs.prompt.md" },
      { "path": "./prompts/refactor.prompt.md" },
      { "path": "./prompts/refine.prompt.md" },
      { "path": "./prompts/ship-check.prompt.md" }
    ],
    "chatSkills": [
      { "path": "./skills/rqmd-brainstorm/SKILL.md" },
      { "path": "./skills/rqmd-bundle/SKILL.md" },
      { "path": "./skills/rqmd-changelog/SKILL.md" },
      { "path": "./skills/rqmd-diagram/SKILL.md" },
      { "path": "./skills/rqmd-doc-sync/SKILL.md" },
      { "path": "./skills/rqmd-docs/SKILL.md" },
      { "path": "./skills/rqmd-export-context/SKILL.md" },
      { "path": "./skills/rqmd-feedback/SKILL.md" },
      { "path": "./skills/rqmd-history/SKILL.md" },
      { "path": "./skills/rqmd-implement/SKILL.md" },
      { "path": "./skills/rqmd-init/SKILL.md" },
      { "path": "./skills/rqmd-init-legacy/SKILL.md" },
      { "path": "./skills/rqmd-pin/SKILL.md" },
      { "path": "./skills/rqmd-status-maintenance/SKILL.md" },
      { "path": "./skills/rqmd-telemetry/SKILL.md" },
      { "path": "./skills/rqmd-triage/SKILL.md" },
      { "path": "./skills/rqmd-verify/SKILL.md" }
    ],
    "chatAgents": [
      { "path": "./agents/rqmd.agent.md" },
      { "path": "./agents/rqmd-dev.agent.md" }
    ]
  }
}
